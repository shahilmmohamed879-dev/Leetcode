class Solution(object):
    def productExceptSelf(self, nums):
        l=len(nums)

        left=1
        right=1
        ans=[1]*l

        for i in range(l):
            ans[i]=left
            left*=nums[i]

        for i in range(l-1,-1,-1):
            ans[i]*=right
            right*=nums[i]

        return ans


        





